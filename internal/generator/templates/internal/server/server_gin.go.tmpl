package server

import (
	"context"
	"fmt"
	"net/http"
	"time"

	"github.com/gin-gonic/gin"
	"github.com/prometheus/client_golang/prometheus/promhttp"
	swaggerFiles "github.com/swaggo/files"
	ginSwagger "github.com/swaggo/gin-swagger"
	"{{.ModulePath}}/internal/config"
	"{{.ModulePath}}/internal/handler"
	"{{.ModulePath}}/internal/middleware"
	"{{.ModulePath}}/pkg/cache"
	"{{.ModulePath}}/pkg/database"
	"{{.ModulePath}}/pkg/logger"

	_ "{{.ModulePath}}/docs" // Import generated docs
)

type Server struct {
	router     *gin.Engine
	httpServer *http.Server
	config     *config.Config
	db         *database.DB
	cache      *cache.Redis
	log        *logger.Logger
}

func New(cfg *config.Config, log *logger.Logger) *Server {
	// Initialize database
	db, err := database.New(cfg.DatabaseURL)
	if err != nil {
		log.Fatal("Failed to connect to database", "error", err)
	}

	// Initialize Redis
	redisClient, err := cache.New(cfg.RedisURL)
	if err != nil {
		log.Fatal("Failed to connect to Redis", "error", err)
	}

	// Set Gin mode based on environment
	if cfg.IsProduction() {
		gin.SetMode(gin.ReleaseMode)
	} else {
		gin.SetMode(gin.DebugMode)
	}

	// Create Gin router
	router := gin.New()

	srv := &Server{
		router: router,
		config: cfg,
		db:     db,
		cache:  redisClient,
		log:    log,
	}

	srv.setupMiddleware()
	srv.setupRoutes()

	// Configure HTTP server with security settings
	srv.httpServer = &http.Server{
		Addr:    fmt.Sprintf(":%d", cfg.AppPort),
		Handler: router,

		// Security: Set timeouts to prevent DoS
		ReadTimeout:       15 * time.Second,
		WriteTimeout:      15 * time.Second,
		IdleTimeout:       120 * time.Second,
		ReadHeaderTimeout: 10 * time.Second,

		// Security: Set max header size (1MB)
		MaxHeaderBytes: 1 << 20,
	}

	return srv
}

func (s *Server) setupMiddleware() {
	// Security: Recovery middleware first to catch panics
	s.router.Use(middleware.Recovery(s.log))

	// Metrics collection
	s.router.Use(middleware.Metrics())

	// Request logging
	s.router.Use(middleware.RequestLogger(s.log))

	// Security headers
	s.router.Use(middleware.SecurityHeaders())

	// CORS
	s.router.Use(middleware.CORS())

	// Security: Limit request body size (4MB)
	s.router.Use(middleware.BodySizeLimit(4 * 1024 * 1024))
}

func (s *Server) setupRoutes() {
	// Prometheus metrics endpoint
	s.router.GET("/metrics", gin.WrapH(promhttp.Handler()))

	// Swagger documentation
	s.router.GET("/swagger/*any", ginSwagger.WrapHandler(swaggerFiles.Handler))

	// Health check endpoints
	health := handler.NewHealthHandler(s.db, s.cache, s.log)

	s.router.GET("/health/live", health.LivenessProbe)
	s.router.GET("/health/ready", health.ReadinessProbe)

	// API routes
	api := s.router.Group("/api/v1")
	{
		// Example: Add your routes here
		api.GET("/", func(c *gin.Context) {
			c.JSON(http.StatusOK, gin.H{
				"message": "Welcome to the API",
				"version": "1.0.0",
			})
		})
	}

	// 404 handler
	s.router.NoRoute(func(c *gin.Context) {
		c.JSON(http.StatusNotFound, gin.H{
			"error": "Route not found",
		})
	})
}

func (s *Server) Start() error {
	s.log.Info("Server starting", "address", s.httpServer.Addr)
	
	// Start server
	if err := s.httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {
		return err
	}
	return nil
}

func (s *Server) Shutdown(ctx context.Context) error {
	s.log.Info("Shutting down server...")

	// Shutdown HTTP server
	if err := s.httpServer.Shutdown(ctx); err != nil {
		s.log.Error("Error during server shutdown", "error", err)
		return err
	}

	// Close database connection
	if err := s.db.Close(); err != nil {
		s.log.Error("Error closing database connection", "error", err)
		return err
	}

	// Close Redis connection
	if err := s.cache.Close(); err != nil {
		s.log.Error("Error closing Redis connection", "error", err)
		return err
	}

	s.log.Info("Server shutdown complete")
	return nil
}
